# Игнорировать бинарные файлы, сгенерированные при сборке
*.exe
*.out
*.test

# Игнорировать временные файлы и каталоги Go
*.log
*.tmp
*.swp
go-build/
vendor/

# Игнорировать зависимости, если вы используете go modules (они хранятся в go.sum)
# (оставьте go.mod и go.sum, так как они нужны для воспроизводимости)
# vendor/ уже покрыт выше, если используете его

# Игнорировать сгенерированный код sqlc
db/sqlc/*.go

# Игнорировать файлы конфигурации с чувствительными данными (например, .env)
.env
*.env

# Игнорировать файлы базы данных и дампы (если создаются локально)
*.sql
*.db
*.sqlite
*.sqlite3

# Игнорировать IDE и редакторы (например, VS Code, GoLand)
.idea/
.vscode/
*.code-workspace

# Игнорировать macOS- и Linux-специфичные файлы
.DS_Store
__pycache__/

# Игнорировать артефакты сборки
dist/
build/

# Игнорировать файлы резервного копирования
*~

# Игнорировать файлы, сгенерированные миграциями (если они не контролируются вручную)
migration/*.down.sql
migration/*.up.sql